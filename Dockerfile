FROM node:24-alpine AS builder
WORKDIR /app

ARG NUXT_BETTER_AUTH_SECRET
ARG NUXT_PUBLIC_SITE_URL
ARG NUXT_PUBLIC_VAPID_PUBLIC_KEY
ARG NUXT_PUBLIC_ENV
ARG NUXT_MONGO_URI
ARG NUXT_MONGO_DB
ARG NUXT_SYSTEM_MAINTENANCE_KEY
ARG NUXT_GOOGLE_CLIENT_ID
ARG NUXT_GOOGLE_CLIENT_SECRET
ARG NUXT_MS_CLIENT_ID
ARG NUXT_MS_CLIENT_SECRET
ARG NUXT_TMDB_API_KEY
ARG NUXT_TMDB_BASE_URL
ARG NUXT_OMDB_API_KEY
ARG NUXT_OMDB_BASE_URL
ARG NUXT_VAPID_PRIVATE_KEY
ARG NUXT_VAPID_SUBJECT

ENV NUXT_BETTER_AUTH_SECRET=$NUXT_BETTER_AUTH_SECRET
ENV NUXT_PUBLIC_SITE_URL=$NUXT_PUBLIC_SITE_URL
ENV NUXT_PUBLIC_VAPID_PUBLIC_KEY=$NUXT_PUBLIC_VAPID_PUBLIC_KEY
ENV NUXT_PUBLIC_ENV=$ENV
ENV NUXT_MONGO_URI=$MONGO_URI
ENV NUXT_MONGO_DB=$MONGO_DB
ENV NUXT_SYSTEM_MAINTENANCE_KEY=$SYSTEM_MAINTENANCE_KEY
ENV NUXT_GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
ENV NUXT_GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
ENV NUXT_MS_CLIENT_ID=$MS_CLIENT_ID
ENV NUXT_MS_CLIENT_SECRET=$MS_CLIENT_SECRET
ENV NUXT_TMDB_API_KEY=$TMDB_API_KEY
ENV NUXT_TMDB_BASE_URL=$TMDB_BASE_URL
ENV NUXT_OMDB_API_KEY=$OMDB_API_KEY
ENV NUXT_OMDB_BASE_URL=$OMDB_BASE_URL
ENV NUXT_VAPID_PRIVATE_KEY=$VAPID_PRIVATE_KEY
ENV NUXT_VAPID_SUBJECT=$VAPID_SUBJECT

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:24-alpine
WORKDIR /app
COPY --from=builder /app/.output ./

EXPOSE 3000
CMD ["node", "server/index.mjs"]