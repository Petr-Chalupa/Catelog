{
    "name": "catelog-frontend",
    "author": "Petr Chalupa",
    "license": "MIT + CC",
    "version": "1.0.0",
    "type": "module",
    "main": "src/main.ts",
    "dependencies": {
        "axios": "^1.14.0",
        "better-auth": "^1.5.6",
        "lucide-vue-next": "^1.0.0",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "vue": "^3.5.31",
        "vue-i18n": "^11.3.0",
        "vue-router": "^5.0.4",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/tsconfig": "^0.9.1",
        "openapi-typescript-codegen": "^0.30.0",
        "typescript": "~6.0.2",
        "vite": "^8.0.3",
        "vite-plugin-pwa": "^1.2.0"
    },
    "overrides": {
        "vite-plugin-pwa": {
            "vite": "$vite"
        }
    },
    "scripts": {
        "gen:api": "npx openapi-typescript-codegen --input ../backend/openapi.yaml --output src/api --client axios",
        "dev": "npm run gen:api && vite",
        "build": "npm run gen:api && vite build",
        "preview": "npm run gen:api && vite preview"
    }
}
